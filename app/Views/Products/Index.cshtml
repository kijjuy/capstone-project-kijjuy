@{
    Layout = "_Layout";
    var categories = ViewData["Categories"];
    ViewData["Title"] = "Products";
}

@model IEnumerable<app.Models.ProductViewModelWithImages>

<div class="row" id="root">

    <div class="col-xxl-3 col-sm-12" id="filter-container">
	<div id="filter-reveal" class="btn btn-primary m-3 p-3">Show Filter</div>
    	
    	<div id="filter-root" class="bg-dark-subtle m-3" hidden>
    	    <form action="/products">
    		<div class="row p-5">
    		    <div class="container p-0">
    			<input class="p-3 rounded container" type="text" name="nameFilter" placeholder="Name"/>
    		    </div>
    		    <div class="container p-0">
			<select class="p-3 rounded container mt-3" name="categoryNameFilter" asp-items="(SelectList)categories" class="form-control">
			    <option value="">-- Select Category --</option> 
			</select>
    		    </div>
    		    <div class="p-0 row m-0 mt-3">
    		        <input class="col-5 rounded p-3" type="number" name="priceMin" placeholder="Min Price">
    		        <p class="col-2 text-center pt-3">to</p>
    		        <input class="col-5 rounded p-3" type="number" name="priceMax" placeholder="Max Price">
    		    </div>
		    <div class="container p-0">
			<div class="d-flex">
			    <select class="p-3 rounded container mt-3" name="sortType" id="sort">
			        <option value="">-- Sort --</option>
			        <option value="price">Price</option>
			        <option value="name">Name</option>
			    </select>
			    <div class="form-check d-flex container justify-content-center align-items-center gap-2 mt-2">
				<div>
				    <input class="form-check-input m-0 " type="checkbox" name="reverseSort">
				</div>
				<div>
				    <label class="form-check-label">Reverse</label>
				</div>
			    </div>
			</div>
		    </div>
    		    <input type="submit" class="mt-3 p-3 btn btn-primary" value="Apply">
    		</div>
    	    </form>
    	</div>
    </div>

    <div class="col-xxl-9 col-sm-12" id="products-container">
	@if(Model.Any()) 
    	{
    	<div class="container">
    	    <div class="row">
    	    @foreach(var product in Model) 
    	    {
    	    <div class="col-sm-12 col-xl-6">
    		<a id="product-card" class="card bg-dark-subtle pb-0 link-underline link-underline-opacity-0" asp-controller="Products" asp-action="Details" asp-route-id="@product.ProductId">
    		    @if(product.ImageNames.Any()) {
		    <div class="ratio ratio-4x3">
			<img class="object-fit-cover" src="/Images/@product.ImageNames.FirstOrDefault()" alt="Image for @product.ProductName">
		    </div>
    		    } else {
    		    <img src="/Images/placeholder.jpg" alt="Image for @product.ProductName">
    		    }
		    <h5 class="p-1">@product.ProductName - @String.Format("{0:C2}", product.Price)</h5>
    		</a>
    		
    	    	<br />
    	    </div>
    	    }
    	    </div>
    	</div>
    	} else {
    	    <h5>No products found. Check back later!</h5>
    	}
    </div>
</div>

@section Scripts{
    <script src="~/js/productIndex.js"></script>
}
