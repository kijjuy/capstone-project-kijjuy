@{
    Layout = "_Layout";
    ViewData["Title"] = Model.ProductName;
}

@model app.Models.ProductViewModelWithImages

<div id="content-root" class="p-3">

    <h1>@Model.ProductName</h1>
    
    @if(Model.ImageNames.Any()) 
    {
    <div id="product-images-carousel" class="carousel slide carousel-dark">
      <div class="carousel-indicators">
    
          @for(int i = 0; i < Model.ImageNames.Count(); i++) 
           {
        <button type="button" data-bs-target="#product-images-carousel" data-bs-slide-to="@i" class="active" aria-current="true" aria-label="Slide 1"></button>
           }
    
      </div>
      <div class="carousel-inner">
    
          @for(int i = 0; i < Model.ImageNames.Count(); i++)  
          {
           @if(i == 0) {
    
        <div class="carousel-item active">
          <img src="/Images/@Model.ImageNames[i]" class="d-block w-100" alt="Product image for @Model.ProductName">
        </div>
    
        } else 
        {
    
        <div class="carousel-item">
          <img src="/Images/@Model.ImageNames[i]" class="d-block w-100" alt="Product image for @Model.ProductName">
        </div>
    
        }
          }
      </div>
      <button class="carousel-control-prev" type="button" data-bs-target="#product-images-carousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
      </button>
      <button class="carousel-control-next" type="button" data-bs-target="#product-images-carousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
      </button>
    </div>

    }
    <div class="row mt-4">
	<h5 class="col-6 text-center">@String.Format("{0:C2}", Model.Price)</h5>
	<a class="btn btn-primary col-6" onClick="addToCart(@Model.ProductId)">Add To Cart</a>
    </div>
    <p class="mt-5">@Model.Description</p>

</div>
<script>
    async function addToCart(productId) {
	var res = await fetch("/api/cart/" + productId, {
	    method: "POST"
	});

	if(res.status == 400) {
	    alert("Product already in cart.");
	    return;
	}

	if(res.status == 500) {
	    alert("Error adding product to cart.");
	}
	alert("Product added to cart.");
    }
</script>
