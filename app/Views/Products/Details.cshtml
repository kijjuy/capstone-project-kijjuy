@{
    Layout = "_Layout";
}

@model app.Models.ProductViewModel 

<h1>Name: @Model.ProductName</h1>
<h3>Category: @Model.CategoryName</h3>
<h3>Price: @Model.Price</h3>
<a onClick="addToCart(@Model.ProductId)" class="btn btn-primary">Add To Cart</a>
<p>@Model.Description</p>

<script>
    async function addToCart(productId) {
	var res = await fetch("/api/cart/" + productId, {
	    method: "POST"
	});

	if(res.status == 400) {
	    alert("Product already in cart.");
	    return;
	}

	if(res.status == 500) {
	    alert("Error adding product to cart.");
	}
	alert("Product added to cart.");
    }
</script>
