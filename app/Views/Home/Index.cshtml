@{
    Layout = "_Layout";
    ViewData["Title"] = "Home";
}

<div id="root" class="container mt-5">
    <div class="d-flex justify-content-center m-5">
	<img class="img-fluid" src="Images/header-img.png" alt="">
    </div>

    <h3 class="font-white font-indie text-center mb-4">Browse by Category</h3>

    <div class="row text-center">
        <div class="col-12 col-sm-6 col-md-4 mb-4">
            <a href="/products?categoryNameFilter=@ViewData["cuttingBoard"]" class="text-decoration-none text-dark">
                <img src="Images/homeImg1.jpg" class="img-fluid rounded" alt="Cutting Boards">
                <p class="font-720c mt-2">Cutting Boards</p>
            </a>
        </div>

        <div class="col-12 col-sm-6 col-md-4 mb-4">
            <a href="/products?categoryNameFilter=@ViewData["charcuterie"]" class="text-decoration-none text-dark">
                <img src="Images/homeImg2.jpg" class="img-fluid rounded" alt="Charcuterie Boards">
                <p class="font-720c mt-2">Charcuterie Boards</p>
            </a>
        </div>

        <div class="col-12 col-sm-6 col-md-4 mb-4">
            <a href="/products?categoryNameFilter=@ViewData["choppingBlock"]" class="text-decoration-none text-dark">
                <img src="Images/homeImg3.jpg" class="img-fluid rounded" alt="Chopping Blocks">
                <p class="font-720c mt-2">Chopping Blocks</p>
            </a>
        </div>
    </div>

    <h3 class="font-white font-indie mt-5 text-center">About Us</h3>
    <p class="font-720c text-center">
	Ward 4 Woods is a small, local woodworking shop that primarily creates artisan cutting and charcuterie boards. <br><br>
	At Ward 4 Woods, we aim to provide exceptional quality products that are crafted with a high level of detail
	and valuable quality assurance to customers in southern Ontario.
    </p>
</div>
