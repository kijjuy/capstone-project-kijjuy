@{
    Layout = "_Layout";
    ViewData["Title"] = "Admin Home";
}

@using app.Models;
@model IEnumerable<ProductViewModel>

<h1 class="text-center mt-3">Admin Panel</h1>

@if(Model.Any()) 
{
<div class="container-fluid">
    <div class="row py-1">
	<div class="col-4"><b>Product Name</b></div>
	<div class="col-4"><b>Product Price</b></div>
	<div class="col-2"><b>Update</b></div>
	<div class="col-2"><b>Delete</b></div>
    </div>
    @foreach(var product in Model) 
    {
    <div class="row py-1">
	<div class="col-4">@product.ProductName</div>
	<div class="col-4">@product.Price</div>
	<div class="col-2">
	    <a asp-controller="Products" asp-action="Update" asp-route-id="@product.ProductId" class="btn btn-primary">Update</a>
	</div>
	<div class="col-2">
	    <a onClick="deleteProduct(@product.ProductId)" class="btn btn-danger">Delete</a>
	</div>
    </div>
    }
</div>

} else {
<h5>No products found. Check back later!</h5>
}

<script>
    async function deleteProduct(productId) {
	console.log("Delete item hit with value " + productId);
	let shouldDelete = confirm(`Are you sure you want to delete product with id=${productId}?`);
	if(!shouldDelete) {
	    return;
	}

	let res = await fetch("/api/products/" + productId, {
	    method: "DELETE"
	});
	if(res.status != 204) {
	    alert("Error deleting product. Please check application logs.");
	    return;
	}
	window.location.reload();
    }
</script>
