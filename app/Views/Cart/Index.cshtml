@{
    Layout = "_Layout";
    ViewData["Title"] = "Cart";
}

@using app.Models
@model CartViewModel

@if(Model != null && Model.Products != null && Model.Products.Any()) {
<a class="border pt-4 p-3 btn btn-primary w-100 h-100" id="checkout-button" asp-controller="Checkout" asp-action="Index">
    <h5 class="text-center">Checkout Now</h5>
    <h5 class="text-center">Subtotal: @String.Format("{0:C2}", Model.Subtotal)</h5>
</a>
<div class="container">

    @for(int i = 0; i < Model.Products.Count(); i++)
    {


    <div class="cart-item row p-2 @(@i % 2 == 0 ? "bg-white" : "bg-dark-subtle")">
	<div class="col-6 p-0 m-0 h-100 d-flex align-items-center justify-content-center">
	    @if(Model.Products[i].ImageNames.Any()) 
	    {
	    <img class="img-fluid mh-100 object-fit-contain" src="/Images/@Model.Products[i].ImageNames[0]" alt="@Model.Products[i].ProductName primary image">
	    } else 
	    {
	    <img class="img-fluid mh-100" src="/Images/placeholder.jpg" alt="placeholder image">
	    }
	</div>
	<div class="col-4">
	    <p class="">@Model.Products[i].ProductName</p>
	    <p class="">@String.Format("{0:C2}", Model.Products[i].Price)</p>
	</div>
	<div class="col-2 d-flex align-items-center justify-content-center h-100">
	    <img data-product-id="@Model.Products[i].ProductId" class="btn cart-delete" src="Images/delete.png" alt="delete button for @Model.Products[i].ProductName">
	</div>
    </div>
    }
</div>
} else 
{
<div class="text-center m-5">
    <h1>Your cart is empty.</h1>
</div>
}

@section Scripts {
    <script src="~/js/cartIndex.js">
    
    </script>
}
